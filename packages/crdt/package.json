{
  "name": "@collabtext/crdt",
  "version": "0.0.0",
  "private": true,
  "description": "From-scratch RGA CRDT core — zero networking/UI dependencies",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/lookup.bench.ts"
  },
  "devDependencies": {
    "fast-check": "^3.23.1",
    "tinybench": "^2.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
